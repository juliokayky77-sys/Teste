<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>PassManager Pro | Controle de Intervalo</title>
    <!-- Font Awesome 6 (Free Icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
        }

        body {
            background: linear-gradient(145deg, #0b2b44 0%, #123e5e 100%);
            padding: 24px 20px;
            min-height: 100vh;
        }

        /* Modern glassmorphism card style */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(0px);
            border-radius: 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.35), 0 2px 8px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            transition: all 0.2s;
        }

        /* header modern */
        .hero-header {
            background: linear-gradient(120deg, #1e2a3a, #0f172a);
            padding: 28px 32px;
            color: white;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        h1 {
            font-size: 1.9rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        h1 i {
            background: #3b82f6;
            padding: 8px;
            border-radius: 20px;
            font-size: 1.3rem;
        }

        .subtitle {
            color: #94a3b8;
            margin-top: 8px;
            font-weight: 500;
            font-size: 0.9rem;
        }

        /* main content padding */
        .main-content {
            padding: 32px;
        }

        /* cards style */
        .card-modern {
            background: white;
            border-radius: 1.5rem;
            padding: 1.8rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02), 0 2px 6px rgba(0, 0, 0, 0.05);
            border: 1px solid #eef2f6;
            transition: box-shadow 0.2s;
        }

        .card-modern:hover {
            box-shadow: 0 20px 28px -12px rgba(0, 0, 0, 0.12);
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 5px solid #3b82f6;
            padding-left: 18px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.4rem;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .input-group label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #334155;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .input-group label i {
            width: 20px;
            color: #3b82f6;
        }

        input, select {
            padding: 12px 14px;
            border: 1.5px solid #e2e8f0;
            border-radius: 14px;
            font-size: 0.9rem;
            transition: all 0.2s;
            background-color: #fefefe;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
        }

        /* button group */
        .btn-group {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.85rem;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #f1f5f9;
            color: #1e293b;
        }

        .btn-primary {
            background: #3b82f6;
            color: white;
            box-shadow: 0 2px 6px rgba(59,130,246,0.3);
        }
        .btn-primary:hover { background: #2563eb; transform: translateY(-2px); }

        .btn-secondary {
            background: #64748b;
            color: white;
        }
        .btn-secondary:hover { background: #475569; transform: translateY(-1px); }

        .btn-success {
            background: #10b981;
            color: white;
        }
        .btn-success:hover { background: #059669; transform: translateY(-2px); }

        .btn-danger {
            background: #ef4444;
            color: white;
        }
        .btn-danger:hover { background: #dc2626; }

        .btn-outline {
            background: transparent;
            border: 1px solid #cbd5e1;
            color: #334155;
        }
        .btn-outline:hover { background: #f8fafc; border-color: #3b82f6; }

        /* modern table */
        .table-wrapper {
            overflow-x: auto;
            border-radius: 20px;
            background: white;
        }

        .student-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .student-table th {
            text-align: left;
            padding: 16px 12px;
            background-color: #f8fafc;
            color: #1e293b;
            font-weight: 700;
            border-bottom: 2px solid #e2e8f0;
        }

        .student-table td {
            padding: 14px 12px;
            border-bottom: 1px solid #ecf3f9;
            vertical-align: middle;
        }

        .student-table tr:hover td {
            background-color: #fef9e3;
        }

        .action-icons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .action-icons button {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            transition: 0.1s;
            padding: 6px;
            border-radius: 40px;
        }

        .badge {
            background: #e2e8f0;
            padding: 4px 10px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* ficha (pass) card premium */
        .ficha-premium {
            background: linear-gradient(135deg, #ffffff 0%, #fef9e6 100%);
            border-radius: 32px;
            padding: 28px;
            border: 1px solid #ffe6b3;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2);
            max-width: 680px;
            margin: 20px auto;
            position: relative;
        }

        .ficha-header-premium {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px dashed #f59e0b;
            padding-bottom: 18px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .ficha-qrcode-sim {
            background: #f1f5f9;
            padding: 8px 14px;
            border-radius: 50px;
            font-family: monospace;
            font-weight: bold;
            letter-spacing: 2px;
        }

        .info-row {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 18px;
        }

        .info-card {
            flex: 1;
            background: #ffffffdd;
            backdrop-filter: blur(2px);
            padding: 12px 16px;
            border-radius: 24px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        .verification-code {
            background: #0f172a;
            color: #facc15;
            font-family: monospace;
            padding: 8px 16px;
            border-radius: 60px;
            text-align: center;
            font-weight: bold;
        }

        .email-preview-area {
            background: #f0f9ff;
            border-radius: 24px;
            padding: 20px;
            margin-top: 24px;
        }

        /* notification */
        .toast-notify {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #1e293b;
            color: white;
            padding: 14px 20px;
            border-radius: 60px;
            z-index: 2000;
            font-weight: 500;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateX(400px);
            transition: transform 0.25s ease;
        }

        .toast-notify.show {
            transform: translateX(0);
        }

        .float-stats {
            background: white;
            border-radius: 60px;
            padding: 6px 18px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: bold;
        }

        footer {
            background: #f1f5f9;
            text-align: center;
            padding: 18px;
            font-size: 0.75rem;
            color: #475569;
            border-top: 1px solid #e2e8f0;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="hero-header">
        <h1><i class="fas fa-passport"></i> PassManager Pro</h1>
        <p class="subtitle"><i class="fas fa-clock"></i> Controle inteligente de acesso ao intervalo | emissão de passes com verificação e simulação de envio</p>
        <div style="margin-top: 12px; display: flex; gap: 16px; flex-wrap: wrap;">
            <span class="float-stats"><i class="fas fa-users"></i> <span id="statCounter">0</span> alunos</span>
            <span class="float-stats"><i class="fas fa-ticket-alt"></i> Último pass gerado: <span id="lastPassLabel">--</span></span>
        </div>
    </div>

    <div class="main-content">
        <!-- Cadastro card -->
        <div class="card-modern">
            <div class="section-title">
                <i class="fas fa-user-graduate"></i> Cadastro de Estudante
            </div>
            <form id="studentForm">
                <div class="form-grid">
                    <div class="input-group"><label><i class="fas fa-user"></i> Nome Completo</label><input type="text" id="nome" placeholder="Nome completo" required></div>
                    <div class="input-group"><label><i class="fas fa-id-card"></i> CPF</label><input type="text" id="cpf" placeholder="000.000.000-00" maxlength="14"></div>
                    <div class="input-group"><label><i class="fas fa-qrcode"></i> Matrícula</label><input type="text" id="matricula" placeholder="Nº matrícula" required></div>
                    <div class="input-group"><label><i class="fas fa-graduation-cap"></i> Curso</label><input type="text" id="curso" placeholder="Ex: Engenharia / Médio" required></div>
                    <div class="input-group"><label><i class="fas fa-layer-group"></i> Série/Turma</label><input type="text" id="serie" placeholder="3° Ano A" required></div>
                    <div class="input-group"><label><i class="fas fa-envelope"></i> E-mail</label><input type="email" id="email" placeholder="estudante@escola.com" required></div>
                </div>
                <div class="btn-group">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Cadastrar Aluno</button>
                    <button type="button" onclick="limparFormulario()" class="btn btn-outline"><i class="fas fa-eraser"></i> Limpar</button>
                    <button type="button" id="importDemoBtn" class="btn btn-secondary"><i class="fas fa-database"></i> Carregar Exemplo</button>
                </div>
            </form>
        </div>

        <!-- Lista de alunos com busca e melhorias -->
        <div class="card-modern">
            <div class="section-title">
                <i class="fas fa-list-ul"></i> Registro Acadêmico
                <span style="margin-left: auto; font-size: 0.8rem;"><i class="fas fa-search"></i> <input type="text" id="searchStudent" placeholder="Buscar nome ou matrícula..." style="padding: 6px 12px; width: 200px;"></span>
            </div>
            <div class="table-wrapper">
                <table class="student-table">
                    <thead>
                        <tr><th>Nome</th><th>Matrícula</th><th>Curso</th><th>Série</th><th class="actions">Ações</th></tr>
                    </thead>
                    <tbody id="studentsList">
                        <tr><td colspan="5" style="text-align:center;">Carregando alunos...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Área da Ficha (Pass) -->
        <div id="fichaContainer" style="display: none;">
            <div class="ficha-premium" id="passPreview">
                <div class="ficha-header-premium">
                    <div><i class="fas fa-school" style="font-size: 1.8rem; color: #f59e0b;"></i> <strong style="font-size: 1.5rem;">PASSE LIVRE</strong></div>
                    <div class="ficha-qrcode-sim"><i class="fas fa-check-circle"></i> VERIFICADO</div>
                </div>
                <div class="info-row">
                    <div class="info-card"><i class="fas fa-user"></i> <strong>Nome:</strong> <span id="fichaNome">---</span></div>
                    <div class="info-card"><i class="fas fa-id-card"></i> <strong>CPF:</strong> <span id="fichaCpf">---</span></div>
                </div>
                <div class="info-row">
                    <div class="info-card"><i class="fas fa-hashtag"></i> <strong>Matrícula:</strong> <span id="fichaMatricula">---</span></div>
                    <div class="info-card"><i class="fas fa-book"></i> <strong>Curso:</strong> <span id="fichaCurso">---</span></div>
                </div>
                <div class="info-row">
                    <div class="info-card"><i class="fas fa-chalkboard-user"></i> <strong>Série:</strong> <span id="fichaSerie">---</span></div>
                    <div class="info-card"><i class="fas fa-envelope"></i> <strong>Email:</strong> <span id="fichaEmail">---</span></div>
                </div>
                <div style="background:#fef3c7; border-radius: 24px; padding: 12px; margin: 12px 0; text-align: center;">
                    <i class="fas fa-clock"></i> Emissão: <span id="fichaData">--</span> &nbsp;|&nbsp;
                    <i class="fas fa-fingerprint"></i> <strong>Código:</strong> <span id="codigoVerificacao">XXXX</span>
                </div>
                <div class="email-preview-area">
                    <h4 style="margin-bottom: 12px;"><i class="fas fa-paper-plane"></i> Enviar Passagem Digital</h4>
                    <div class="input-group" style="flex-direction: row; align-items: center; gap: 12px; flex-wrap: wrap;">
                        <label><i class="fas fa-at"></i> Email destino:</label>
                        <input type="email" id="emailDestino" style="flex:2;" placeholder="destino@email.com">
                        <button id="btnSendEmail" class="btn btn-success"><i class="fas fa-envelope-open-text"></i> Enviagemo</button>
                    </div>
                    <small class="badge"><i class="fas fa-info-circle"></i> Simulação de envio com registro no console + notificação</small>
                </div>
                <div class="btn-group" style="justify-content: center; margin-top: 20px;">
                    <button onclick="window.print()" class="btn btn-outline"><i class="fas fa-print"></i> Imprimir Pass</button>
                    <button onclick="fecharFicha()" class="btn btn-secondary"><i class="fas fa-times"></i> Fechar</button>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <i class="fas fa-laptop-code"></i> PassManager Pro • Sistema seguro de emissão de passes de intervalo • Dados salvos localmente
    </footer>
</div>

<div id="globalToast" class="toast-notify"><i class="fas fa-bell"></i> <span id="toastMsg">Mensagem</span></div>

<script>
    // ======================== Gerenciamento de dados ======================
    let alunos = JSON.parse(localStorage.getItem('alunos_profissional')) || [];
    let alunoAtual = null;

    // helpers
    function formatarCPF(cpf) {
        let cleaned = cpf.replace(/\D/g, '');
        if(cleaned.length <= 11) {
            cleaned = cleaned.padStart(11, '0').slice(0,11);
            return cleaned.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
        }
        return cpf;
    }

    function gerarCodigoUnico() {
        return Math.random().toString(36).substring(2, 10).toUpperCase() + "-" + Math.floor(1000 + Math.random() * 9000);
    }

    function showToast(message, type = "success") {
        const toast = document.getElementById('globalToast');
        const spanMsg = document.getElementById('toastMsg');
        spanMsg.innerText = message;
        toast.style.background = type === "error" ? "#b91c1c" : "#0f172a";
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2800);
    }

    function salvarAlunos() {
        localStorage.setItem('alunos_profissional', JSON.stringify(alunos));
        atualizarListaAlunos();
        atualizarContador();
    }

    function atualizarContador() {
        document.getElementById('statCounter').innerText = alunos.length;
    }

    function limparFormulario() {
        document.getElementById('studentForm').reset();
    }

    // validação e adicionar
    function adicionarAluno(event) {
        event.preventDefault();
        const nome = document.getElementById('nome').value.trim();
        const cpf = document.getElementById('cpf').value.trim();
        const matricula = document.getElementById('matricula').value.trim();
        const curso = document.getElementById('curso').value.trim();
        const serie = document.getElementById('serie').value.trim();
        const email = document.getElementById('email').value.trim();

        if(!nome || !cpf || !matricula || !curso || !serie || !email) {
            showToast("Preencha todos os campos obrigatórios!", "error");
            return;
        }
        if(alunos.some(a => a.matricula === matricula)) {
            showToast("Matrícula já registrada no sistema.", "error");
            return;
        }
        const novoAluno = {
            id: Date.now(),
            nome, cpf: formatarCPF(cpf), matricula, curso, serie, email
        };
        alunos.push(novoAluno);
        salvarAlunos();
        limparFormulario();
        showToast(`✅ Aluno ${nome} cadastrado com sucesso!`);
    }

    function removerAluno(id) {
        if(confirm("Remover este estudante permanentemente?")){
            alunos = alunos.filter(a => a.id !== id);
            salvarAlunos();
            showToast("Aluno removido.", "success");
            if(alunoAtual && alunoAtual.id === id) fecharFicha();
        }
    }

    function gerarFicha(aluno) {
        alunoAtual = aluno;
        document.getElementById('fichaNome').innerText = aluno.nome;
        document.getElementById('fichaCpf').innerText = aluno.cpf;
        document.getElementById('fichaMatricula').innerText = aluno.matricula;
        document.getElementById('fichaCurso').innerText = aluno.curso;
        document.getElementById('fichaSerie').innerText = aluno.serie;
        document.getElementById('fichaEmail').innerText = aluno.email;
        const now = new Date().toLocaleString('pt-BR');
        document.getElementById('fichaData').innerText = now;
        const codigo = gerarCodigoUnico();
        document.getElementById('codigoVerificacao').innerText = codigo;
        document.getElementById('emailDestino').value = aluno.email;
        document.getElementById('fichaContainer').style.display = 'block';
        document.getElementById('lastPassLabel').innerHTML = aluno.nome.split(' ')[0];
        window.scrollTo({ top: document.getElementById('fichaContainer').offsetTop - 20, behavior: 'smooth' });
    }

    function fecharFicha() {
        document.getElementById('fichaContainer').style.display = 'none';
        alunoAtual = null;
    }

    // ENVIO DE EMAIL SIMULADO (profissional com log e relatório)
    function enviarEmailProfissional() {
        if(!alunoAtual) {
            showToast("Nenhuma ficha ativa. Gere um passe primeiro.", "error");
            return;
        }
        const emailDestino = document.getElementById('emailDestino').value.trim();
        if(!emailDestino || !emailDestino.includes('@')) {
            showToast("Email de destino inválido.", "error");
            return;
        }
        const codigo = document.getElementById('codigoVerificacao').innerText;
        const dataEmissao = document.getElementById('fichaData').innerText;
        // simulação profissional com log detalhado
        console.group("📧 ENVIO DE PASS - SIMULAÇÃO AVANÇADA");
        console.log(`✅ Destino: ${emailDestino}`);
        console.log(`📄 Assunto: Passagem de Intervalo - ${alunoAtual.nome}`);
        console.log(`👤 Aluno: ${alunoAtual.nome} (${alunoAtual.matricula})`);
        console.log(`🔑 Código Verificador: ${codigo}`);
        console.log(`⏱️ Emissão: ${dataEmissao}`);
        console.log(`📎 Anexo simbólico: pass_${alunoAtual.matricula}.pdf (modo demo)`);
        console.groupEnd();
        showToast(`📨 Simulação: Passagem enviada para ${emailDestino} (demo, ver console)`, "success");
        // Extra: botão inteligente: podemos adicionar um relatório
        gerarLogEnvio(emailDestino, alunoAtual, codigo);
    }

    function gerarLogEnvio(email, aluno, codigo) {
        // apenas para feedback extra
        const logArea = document.createElement('div');
        logArea.style.display = 'none';
        document.body.appendChild(logArea);
        // não necessário, mas profissional
    }

    // atualizar lista com busca dinâmica
    function atualizarListaAlunos(busca = "") {
        const tbody = document.getElementById('studentsList');
        const searchTerm = busca.toLowerCase();
        let filtered = alunos;
        if(busca) {
            filtered = alunos.filter(a => a.nome.toLowerCase().includes(searchTerm) || a.matricula.toLowerCase().includes(searchTerm));
        }
        if(filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;">Nenhum aluno encontrado</td></tr>`;
            return;
        }
        tbody.innerHTML = "";
        filtered.forEach(aluno => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td style="font-weight:500;">${escapeHtml(aluno.nome)}</td>
                <td><span class="badge">${escapeHtml(aluno.matricula)}</span></td>
                <td>${escapeHtml(aluno.curso)}</td>
                <td>${escapeHtml(aluno.serie)}</td>
                <td class="action-icons">
                    <button onclick='gerarFicha(${JSON.stringify(aluno)})' class="btn" style="background:#eef2ff; color:#2563eb;"><i class="fas fa-ticket-alt"></i> Pass</button>
                    <button onclick='removerAluno(${aluno.id})' class="btn" style="background:#fee2e2; color:#b91c1c;"><i class="fas fa-trash-alt"></i></button>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function escapeHtml(str) {
        if(!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if(m === '&') return '&amp;';
            if(m === '<') return '&lt;';
            if(m === '>') return '&gt;';
            return m;
        });
    }

    // carregar dados demo com botão extra
    function carregarExemplos() {
        if(alunos.length > 0 && confirm("Já existem alunos. Deseja adicionar exemplos mesmo assim? (não duplicará matrículas)")) {
            const exemplos = [
                {id: Date.now()+1, nome: "Ana Beatriz Costa", cpf: "111.222.333-44", matricula: "2024101", curso: "Ensino Médio", serie: "2° Ano B", email: "ana.costa@escola.com"},
                {id: Date.now()+2, nome: "Carlos Eduardo Lima", cpf: "555.666.777-88", matricula: "2024102", curso: "Técnico Informática", serie: "3° Módulo", email: "carlos.lima@tec.br"}
            ];
            let added = 0;
            for(let ex of exemplos) {
                if(!alunos.some(a => a.matricula === ex.matricula)) {
                    alunos.push(ex);
                    added++;
                }
            }
